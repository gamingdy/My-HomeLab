---
import {Code} from "@astrojs/starlight/components";

const GITHUB_BASE_URL: string = "https://raw.githubusercontent.com/gamingdy/My-HomeLab/refs/heads/main/";

// Props for the component
let {url, language, isGithub, lineStart, lineEnd,...props} = Astro.props;

if (!url) {
    throw new Error("URL is required to fetch data.");
}

if (isGithub) {
    url = `${GITHUB_BASE_URL}/${url}`;
}

// Fetch data during server-side rendering
let data = "";
try {
    const response = await fetch(url);
    if (!response.ok) {
        console.error(new Error(`Failed to fetch data: ${response.statusText}`));
    } else {
        data = await response.text();

        if (lineStart !== undefined || lineEnd !== undefined) {
            const startLine = lineStart == null ? 1:Number(lineStart);
            const endLine = lineEnd == null ? undefined: Number(lineEnd);

            const prefix = startLine > 1 ? "...\n" : "";
            const suffix = endLine == null ? "" : "\n...";
            data = prefix + data.split(/\r?\n/).slice(startLine - 1,endLine).join("\n") +suffix;
        }
    }
} catch (error) {
    console.error(error);
}
---

<!-- Component rendering -->
<Code code={data} lang={language} startLineNumber={lineStart ? lineStart -1 : undefined} {...props}  />
